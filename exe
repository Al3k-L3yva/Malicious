edUser" -ForegroundColor Red        Write-Host "      Por             : $subject" -ForegroundColor Yellow        Write-Host ""    }}# 3. Listar TODOS los miembros actuales del grupo Administradores LocalWrite-Host "MIEMBROS ACTUALES DEL GRUPO ADMINISTRADORES LOCAL:" -ForegroundColor Cyantry {    $admins = net localgroup Administradores 2>$null    if (-not $admins) { $admins = net localgroup Administrators 2>$null } # Fallback para sistemas en inglés        $isClean = $true    $admins | Select-String -Pattern "^\s{2,}\S" | ForEach-Object {        $member = $_.Line.Trim()        # Excluir cuentas legítimas conocidas        if ($member -notin @("Administrator", "Administrador")) {            Write-Host "  $member" -ForegroundColor Yellow            $isClean = $false        }    }        if ($isClean) {        Write-Host " Solo cuentas legítimas encontradas" -ForegroundColor Green    }} catch {    Write-Host "No se pudo enumerar el grupo de administradores" -ForegroundColor Red}# 4. Verificar cuentas con privilegios elevados pero sin contraseña o con descripción sospechosaWrite-Host ""Write-Host " CUENTAS LOCALES CON INDICADORES SOSPECHOSOS:" -ForegroundColor Cyan$localUsers = Get-LocalUser -ErrorAction SilentlyContinue$suspiciousFound = $falseforeach ($user in $localUsers) {    $indicators = @()        # Cuenta creada recientemente (últimas 2 horas)    if ($user.WhenCreated -and $user.WhenCreated -gt (Get-Date).AddHours(-2)) {        $indicators += "CREADA RECIENTEMENTE"    }        # Cuenta sin contraseña    if (-not $user.PasswordLastSet) {        $indicators += "SIN CONTRASEÑA ESTABLECIDA"    }        # Nombre sospechoso (patrones comunes de atacantes)    if ($user.Name -match '^(admin|test|backup|svc|temp|support|helpdesk)$') {        $indicators += "NOMBRE SOSPECHOSO"    }        # Cuenta deshabilitada pero con privilegios (técnica de ocultamiento)    if (-not $user.Enabled -and $user.SID -notlike "*-500") {        $indicators += "DESHABILITADA PERO EXISTENTE"    }        if ($indicators.Count -gt 0) {        Write-Host "    $($user.Name)" -ForegroundColor Yellow        foreach ($indicator in $indicators) {            Write-Host "       └─ $indicator" -ForegroundColor Orange        }        $suspiciousFound = $true    }}if (-not $suspiciousFound) {    Write-Host "   No se encontraron cuentas locales sospechosas" -ForegroundColor Green}Write-Host "=" * 70

